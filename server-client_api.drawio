        <mxCell id="ErjgTOEo9CrdRjz5BF8E-5" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;STATUS&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;OK&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;ERROR&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;SERVER_ERROR&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;WRONG_CLIENT_INPUT&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;UNKNOWN_CLIENT&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;whiteSpace=wrap;" vertex="1" parent="1">
