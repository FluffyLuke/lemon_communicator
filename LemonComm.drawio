        </mxCell>
        <mxCell id="1R0UW5tSQW-h5rIoNQk9-45" value="&lt;h1&gt;Lemon Communicator&lt;/h1&gt;&lt;p&gt;is designed to provide secure and private connetions over a network. Clients find each other in the network by the centralized server (hub). Communication takes place directly between clients.&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="280" height="150" as="geometry" />
        </mxCell>
        <mxCell id="P2x3CETgAQtdfEMp_2Vj-2" value="&lt;h1&gt;Server (Hub)&lt;/h1&gt;&lt;p&gt;serves as a meeting place for all the clients.&amp;nbsp;&lt;br&gt;It&#39;s the first thing client connects to and holds this connection through the session.&amp;nbsp;&lt;br&gt;&lt;br&gt;Connection is bidirectional:&lt;br&gt;- server continuously sends information about the state of network.&lt;br&gt;- client updates server about its state, if changes accur (ip change, port change, exit from network...)&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="310" y="20" width="280" height="190" as="geometry" />
        </mxCell>
        <mxCell id="P2x3CETgAQtdfEMp_2Vj-4" value="" style="fontColor=#0066CC;verticalAlign=top;verticalLabelPosition=bottom;labelPosition=center;align=center;html=1;outlineConnect=0;fillColor=#CCCCCC;strokeColor=#6881B3;gradientColor=none;gradientDirection=north;strokeWidth=2;shape=mxgraph.networks.server;" parent="1" vertex="1">
          <mxGeometry x="470" y="20" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="P2x3CETgAQtdfEMp_2Vj-5" value="" style="html=1;verticalLabelPosition=bottom;align=center;labelBackgroundColor=#ffffff;verticalAlign=top;strokeWidth=2;strokeColor=#0080F0;shadow=0;dashed=0;shape=mxgraph.ios7.icons.mail;" parent="1" vertex="1">
          <mxGeometry x="555" y="220" width="60" height="40" as="geometry" />
        </mxCell>
        <mxCell id="P2x3CETgAQtdfEMp_2Vj-7" value="" style="fontColor=#0066CC;verticalAlign=top;verticalLabelPosition=bottom;labelPosition=center;align=center;html=1;outlineConnect=0;fillColor=#CCCCCC;strokeColor=#6881B3;gradientColor=none;gradientDirection=north;strokeWidth=2;shape=mxgraph.networks.pc;" parent="1" vertex="1">
          <mxGeometry x="690" y="20" width="50" height="40" as="geometry" />
        </mxCell>
        <mxCell id="P2x3CETgAQtdfEMp_2Vj-8" value="&lt;h1&gt;Client&lt;/h1&gt;&lt;p&gt;is a single peer that becomes visible to all other peers once it connects to the Hub. It happens via on-premises app. After connecting, client will be able to communicate with other peers in the network.&lt;br&gt;&lt;/p&gt;&lt;p&gt;Client is anonymous and does not require authentication.&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="610" y="20" width="285" height="180" as="geometry" />
        </mxCell>
        <mxCell id="P2x3CETgAQtdfEMp_2Vj-9" value="&lt;h1&gt;Communication&lt;/h1&gt;&lt;p&gt;between peers takes place directly between them. Connection is encrypted and allows for message and file transfer. Received files and messages will be stored at client&#39;s device.&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="884" y="20" width="285" height="180" as="geometry" />
        </mxCell>
        <mxCell id="P2x3CETgAQtdfEMp_2Vj-10" value="" style="html=1;verticalLabelPosition=bottom;align=center;labelBackgroundColor=#ffffff;verticalAlign=top;strokeWidth=2;strokeColor=#0080F0;shadow=0;dashed=0;shape=mxgraph.ios7.icons.mail;" parent="1" vertex="1">
          <mxGeometry x="1080" y="25" width="50" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
